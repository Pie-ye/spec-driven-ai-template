{
  "enabled": true,
  "filesystem": {
    "read_only": ["/usr", "/bin", "/lib", "/lib64", "/etc/ssl/certs"],
    "read_write": [".", "./.trellis", "./.pi", "/tmp"],
    "deny": ["~/.ssh", "~/.gnupg", "~/.aws", "~/.config/gcloud", "~/.config/ai", "~/.pi/agent/auth.json"]
  },
  "network": {
    "allow": ["registry.npmjs.org", "pypi.org", "files.pythonhosted.org", "api.openai.com", "api.x.ai", "docs.github.com", "pi.dev", "docs.trytrellis.app"],
    "deny_all_others": true
  },
  "process": {
    "allow": ["git *", "pnpm *", "npm *", "python *", "pytest *", "go *", "bash ./.trellis/scripts/verify.sh"]
  }
}
